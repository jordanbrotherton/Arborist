#!@PYTHON@

import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'

if os.environ.get('APPDIR'):
    prefix = os.environ.get('APPDIR')
    pkgdatadir = os.path.join(prefix, 'usr/share/arborist')
    localedir = os.path.join(prefix, 'usr/share/locale')
else:
    pkgdatadir = '@pkgdatadir@'
    localedir = '@localedir@'

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)
locale.bindtextdomain('arborist', localedir)
locale.textdomain('arborist')
gettext.install('arborist', localedir)

if __name__ == '__main__':
    import gi

    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'arborist.gresource'))
    resource._register()

    from arborist import main
    sys.exit(main.main(VERSION))
